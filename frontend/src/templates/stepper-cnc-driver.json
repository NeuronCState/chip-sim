{
  "id": "stepper-cnc-driver",
  "name": "A4988步进驱动器",
  "nameEn": "A4988 Stepper Motor Driver",
  "category": "embedded",
  "difficulty": 2,
  "description": "MCU通过STEP/DIR信号控制A4988驱动器驱动NEMA17步进电机，可调细分和电流",
  "descriptionEn": "MCU controls A4988 driver to drive NEMA17 stepper motor via STEP/DIR signals, adjustable microstepping and current",
  "components": [
    { "type": "mcu", "name": "U1", "position": { "x": 100, "y": 200 }, "value": { "value": 3.3, "unit": "V" } },
    { "type": "stepper_motor", "name": "M1", "position": { "x": 500, "y": 180 }, "value": { "value": 12, "unit": "V" } },
    { "type": "resistor", "name": "R1", "position": { "x": 300, "y": 150 }, "value": { "value": 100, "unit": "Ω" } },
    { "type": "resistor", "name": "R2", "position": { "x": 300, "y": 220 }, "value": { "value": 100, "unit": "Ω" } },
    { "type": "capacitor", "name": "C1", "position": { "x": 380, "y": 80 }, "value": { "value": 100e-6, "unit": "F" } },
    { "type": "resistor", "name": "Rs", "position": { "x": 380, "y": 320 }, "value": { "value": 0.1, "unit": "Ω" } },
    { "type": "dc_source", "name": "VCC", "position": { "x": 280, "y": 40 }, "value": { "value": 12, "unit": "V" } },
    { "type": "dc_source", "name": "V_logic", "position": { "x": 60, "y": 60 }, "value": { "value": 3.3, "unit": "V" } },
    { "type": "ground", "name": "GND", "position": { "x": 300, "y": 420 }, "value": { "value": 0, "unit": "V" } }
  ],
  "connections": [
    { "from": "U1:0", "to": "R1:0" },
    { "from": "R1:1", "to": "M1:0" },
    { "from": "U1:1", "to": "R2:0" },
    { "from": "R2:1", "to": "M1:1" },
    { "from": "VCC:1", "to": "C1:0" },
    { "from": "C1:1", "to": "GND:0" },
    { "from": "VCC:1", "to": "M1:2" },
    { "from": "M1:3", "to": "Rs:0" },
    { "from": "Rs:1", "to": "GND:0" },
    { "from": "V_logic:1", "to": "U1:2" },
    { "from": "VCC:0", "to": "GND:0" },
    { "from": "V_logic:0", "to": "GND:0" }
  ],
  "simulationNotes": {
    "zh": "运行数字仿真，MCU输出STEP脉冲控制步进角度（每个脉冲1步或微步），DIR控制方向。C1大电容滤波VCC，Rs设定电流限制（Imax=Vref/(8×Rs)）。",
    "en": "Run digital simulation. MCU outputs STEP pulses to control stepping angle (one step or microstep per pulse), DIR controls direction. C1 bulk cap filters VCC, Rs sets current limit (Imax=Vref/(8×Rs))."
  }
}
