{
  "id": "ir-remote-recv",
  "name": "VS1838红外遥控接收",
  "nameEn": "VS1838 Infrared Remote Receiver",
  "category": "embedded",
  "difficulty": 2,
  "description": "MCU通过VS1838红外接收头解码NEC协议遥控器按键信号",
  "descriptionEn": "MCU decodes NEC protocol remote control key signals via VS1838 IR receiver",
  "components": [
    { "type": "mcu", "name": "U1", "position": { "x": 120, "y": 200 }, "value": { "value": 5, "unit": "V" } },
    { "type": "photodiode", "name": "U2", "position": { "x": 400, "y": 180 }, "value": { "value": 38000, "unit": "Hz" } },
    { "type": "led", "name": "LED1", "position": { "x": 400, "y": 300 }, "value": { "value": 2, "unit": "V" } },
    { "type": "resistor", "name": "R1", "position": { "x": 300, "y": 300 }, "value": { "value": 330, "unit": "Ω" } },
    { "type": "dc_source", "name": "VCC", "position": { "x": 80, "y": 60 }, "value": { "value": 5, "unit": "V" } },
    { "type": "ground", "name": "GND", "position": { "x": 300, "y": 420 }, "value": { "value": 0, "unit": "V" } }
  ],
  "connections": [
    { "from": "VCC:1", "to": "U2:0" },
    { "from": "U2:1", "to": "U1:0" },
    { "from": "U2:2", "to": "GND:0" },
    { "from": "U1:1", "to": "R1:0" },
    { "from": "R1:1", "to": "LED1:0" },
    { "from": "LED1:1", "to": "GND:0" },
    { "from": "VCC:1", "to": "U1:2" },
    { "from": "VCC:0", "to": "GND:0" },
    { "from": "U1:3", "to": "GND:0" }
  ],
  "simulationNotes": {
    "zh": "运行数字仿真，VS1838内部38kHz带通滤波器解调红外载波。NEC协议：引导码9ms低+4.5ms高，32位数据（地址16+命令16+反码），LED指示按键。",
    "en": "Run digital simulation. VS1838 internal 38kHz bandpass filter demodulates IR carrier. NEC protocol: leader 9ms LOW+4.5ms HIGH, 32-bit data (address 16+command 16+inverse). LED indicates key press."
  }
}
