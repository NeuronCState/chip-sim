    { "from": "BZ1:1", "to": "Q1:1" },
    { "from": "Q1:2", "to": "GND:0" },
    { "from": "VCC:1", "to": "U1:1" },
    { "from": "VCC:0", "to": "GND:0" },
    { "from": "U1:2", "to": "GND:0" }
